# list of files/directories to NOT commit to the git repo

# AWS keys
.aws/

# mbtiles file (too large for git — download separately via Google Drive)
tiles/*.mbtiles

# claude details 
.claude/

# python cache 
__pycache__/
*.pyc
*.pyo

# ignore the DS_Store stuff
.DS_Store

# build artifacts
STORM.app
*.iconset/

# icon source and generator — dev only, icons committed directly
storm.png
scripts/create_icon.py

# no device-specific python env files
*.egg-info/

# ignore the data used to test the app 
*.log
veh_data/
