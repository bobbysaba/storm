# list of files/directories to NOT commit to the git repo

# AWS keys
.aws/

# mbtiles file (too large for git — download separately via Google Drive)
tiles/*.mbtiles

# claude details 
.claude/

# python cache 
__pycache__/
*.pyc
*.pyo

# ignore the DS_Store stuff
.DS_Store

# build artifacts (regenerated by create_icon.py / create_app.sh)
STORM.app
storm.icns
*.iconset/

# no device-specific python env files
*.egg-info/

# ignore the data used to test the app 
*.log
veh_data/
